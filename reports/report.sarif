{ "$schema": "https://docs.oasis-open.org/sarif/sarif/v2.1.0/errata01/os/schemas/sarif-schema-2.1.0.json", "version": "2.1.0", "runs": [ {"tool": { "driver": {"name": "C/C++test","semanticVersion": "2026.1.0","rules": [{ "id": "MISRAC2025-RULE_2_8-c", "name": "A project should not contain unused local variables", "shortDescription": { "text": "A project should not contain unused local variables" }, "fullDescription": { "text": "A project should not contain unused local variables [MISRAC2025-RULE_2_8-c]" }, "defaultConfiguration": { "level": "warning" }, "help": { "text": "https:\/\/localhost:8443\/grs\/dtp\/rulesdoc\/com.parasoft.xtest.cpp.analyzer.static.pattern\/10.7.3\/MISRAC2025-RULE_2_8-c.html", "markdown": "[A project should not contain unused local variables \\[MISRAC2025-RULE_2_8-c\\]](https:\/\/localhost:8443\/grs\/dtp\/rulesdoc\/com.parasoft.xtest.cpp.analyzer.static.pattern\/10.7.3\/MISRAC2025-RULE_2_8-c.html)" }, "helpUri": "https:\/\/localhost:8443\/grs\/dtp\/rulesdoc\/com.parasoft.xtest.cpp.analyzer.static.pattern\/10.7.3\/MISRAC2025-RULE_2_8-c.html", "properties": { "tags": [ "MISRA C 2025", "Rule 2.8 (Advisory) A project should not contain unused object definitions" ] } }, { "id": "MISRAC2025-RULE_2_7-a", "name": "There should be no unused parameters in functions", "shortDescription": { "text": "There should be no unused parameters in functions" }, "fullDescription": { "text": "There should be no unused parameters in functions [MISRAC2025-RULE_2_7-a]" }, "defaultConfiguration": { "level": "warning" }, "help": { "text": "https:\/\/localhost:8443\/grs\/dtp\/rulesdoc\/com.parasoft.xtest.cpp.analyzer.static.pattern\/10.7.3\/MISRAC2025-RULE_2_7-a.html", "markdown": "[There should be no unused parameters in functions \\[MISRAC2025-RULE_2_7-a\\]](https:\/\/localhost:8443\/grs\/dtp\/rulesdoc\/com.parasoft.xtest.cpp.analyzer.static.pattern\/10.7.3\/MISRAC2025-RULE_2_7-a.html)" }, "helpUri": "https:\/\/localhost:8443\/grs\/dtp\/rulesdoc\/com.parasoft.xtest.cpp.analyzer.static.pattern\/10.7.3\/MISRAC2025-RULE_2_7-a.html", "properties": { "tags": [ "MISRA C 2025", "Rule 2.7 (Advisory) A function should not contain unused parameters" ] } }, { "id": "MISRAC2025-RULE_17_3-a", "name": "Functions shall always have visible prototype at the function call", "shortDescription": { "text": "Functions shall always have visible prototype at the function call" }, "fullDescription": { "text": "Functions shall always have visible prototype at the function call [MISRAC2025-RULE_17_3-a]" }, "defaultConfiguration": { "level": "error" }, "help": { "text": "https:\/\/localhost:8443\/grs\/dtp\/rulesdoc\/com.parasoft.xtest.cpp.analyzer.static.pattern\/10.7.3\/MISRAC2025-RULE_17_3-a.html", "markdown": "[Functions shall always have visible prototype at the function call \\[MISRAC2025-RULE_17_3-a\\]](https:\/\/localhost:8443\/grs\/dtp\/rulesdoc\/com.parasoft.xtest.cpp.analyzer.static.pattern\/10.7.3\/MISRAC2025-RULE_17_3-a.html)" }, "helpUri": "https:\/\/localhost:8443\/grs\/dtp\/rulesdoc\/com.parasoft.xtest.cpp.analyzer.static.pattern\/10.7.3\/MISRAC2025-RULE_17_3-a.html", "properties": { "tags": [ "MISRA C 2025", "Rule 17.3 (Mandatory) A function shall not be declared implicitly" ] } }, { "id": "MISRAC2025-RULE_17_7-a", "name": "The value returned by a function having non-void return type shall be used", "shortDescription": { "text": "The value returned by a function having non-void return type shall be used" }, "fullDescription": { "text": "The value returned by a function having non-void return type shall be used [MISRAC2025-RULE_17_7-a]" }, "defaultConfiguration": { "level": "error" }, "help": { "text": "https:\/\/localhost:8443\/grs\/dtp\/rulesdoc\/com.parasoft.xtest.cpp.analyzer.static.pattern\/10.7.3\/MISRAC2025-RULE_17_7-a.html", "markdown": "[The value returned by a function having non-void return type shall be used \\[MISRAC2025-RULE_17_7-a\\]](https:\/\/localhost:8443\/grs\/dtp\/rulesdoc\/com.parasoft.xtest.cpp.analyzer.static.pattern\/